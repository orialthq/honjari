{
  "rules": {
    "venues": { ".read": true, ".write": false },
    "presence": {
      "$venueId": {
        ".read": true,
        "$uid": { ".write": "$uid === auth.uid" }
      }
    },
    "userStatus": {
      "$uid": { ".read": "$uid === auth.uid", ".write": "$uid === auth.uid" }
    }
  }
}
